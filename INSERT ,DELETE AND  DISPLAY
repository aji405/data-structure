#include <stdio.h>

int main() {
    int a[100], n, i, pos, item;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter array elements:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    /* Insert */
    printf("Enter position to insert: ");
    scanf("%d", &pos);
    printf("Enter element to insert: ");
    scanf("%d", &item);

    for(i = n; i >= pos; i--)
        a[i] = a[i - 1];

    a[pos - 1] = item;
    n++;

    /* Delete */
    printf("Enter position to delete: ");
    scanf("%d", &pos);

    for(i = pos - 1; i < n - 1; i++)
        a[i] = a[i + 1];

    n--;

    /* Display */
    printf("Array elements are:\n");
    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    return 0;
}
