#include <stdio.h>

#define V 5
#define INF 9999

int main() {
    int graph[V][V] = {
        {0, 10, 0, 30, 100},
        {10, 0, 50, 0, 0},
        {0, 50, 0, 20, 10},
        {30, 0, 20, 0, 60},
        {100, 0, 10, 60, 0}
    };

    int dist[V], visited[V] = {0};
    int i, j, min, u;

    for(i = 0; i < V; i++)
        dist[i] = INF;

    dist[0] = 0;

    for(i = 0; i < V - 1; i++) {
        min = INF;

        for(j = 0; j < V; j++) {
            if(!visited[j] && dist[j] < min) {
                min = dist[j];
                u = j;
            }
        }

        visited[u] = 1;

        for(j = 0; j < V; j++) {
            if(graph[u][j] && !visited[j] &&
               dist[u] + graph[u][j] < dist[j]) {
                dist[j] = dist[u] + graph[u][j];
            }
        }
    }

    printf("Shortest distances from source vertex 0:\n");
    for(i = 0; i < V; i++)
        printf("0 -> %d = %d\n", i, dist[i]);

    return 0;
}
