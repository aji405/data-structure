#include <stdio.h>

struct node {
    int data;
    struct node *left, *right;
};

struct node n1 = {10, NULL, NULL};
struct node n2 = {20, NULL, NULL};
struct node n3 = {30, NULL, NULL};

void inorder(struct node *root) {
    if(root != NULL) {
        inorder(root->left);
        printf("%d ", root->data);
        inorder(root->right);
    }
}

void preorder(struct node *root) {
    if(root != NULL) {
        printf("%d ", root->data);
        preorder(root->left);
        preorder(root->right);
    }
}

void postorder(struct node *root) {
    if(root != NULL) {
        postorder(root->left);
        postorder(root->right);
        printf("%d ", root->data);
    }
}

int main() {
    n1.left = &n2;
    n1.right = &n3;

    printf("Inorder: ");
    inorder(&n1);

    printf("\nPreorder: ");
    preorder(&n1);

    printf("\nPostorder: ");
    postorder(&n1);

    return 0;
