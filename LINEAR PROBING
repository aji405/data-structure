#include <stdio.h>

int main() {
    int hash[10], key, i, loc, n;

    for(i = 0; i < 10; i++)
        hash[i] = -1;

    printf("Enter number of keys: ");
    scanf("%d", &n);

    printf("Enter keys:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &key);

        loc = key % 10;

        while(hash[loc] != -1)
            loc = (loc + 1) % 10;

        hash[loc] = key;
    }

    printf("Hash Table:\n");
    for(i = 0; i < 10; i++)
        printf("%d : %d\n", i, hash[i]);

    return 0;
}
