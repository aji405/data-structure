#include <stdio.h>

int parent[10];

int find(int i) {
    while(parent[i])
        i = parent[i];
    return i;
}

int uni(int i, int j) {
    if(i != j) {
        parent[j] = i;
        return 1;
    }
    return 0;
}

int main() {
    int n = 4;
    int cost[4][4] = {
        {999, 10, 6, 5},
        {10, 999, 0, 15},
        {6, 0, 999, 4},
        {5, 15, 4, 999}
    };

    int i, j, a, b, u, v;
    int min, mincost = 0, edges = 0;

    printf("Edges in MST:\n");

    while(edges < n - 1) {
        min = 999;

        for(i = 0; i < n; i++) {
            for(j = 0; j < n; j++) {
                if(cost[i][j] < min && cost[i][j] != 0) {
                    min = cost[i][j];
                    a = u = i;
                    b = v = j;
                }
            }
        }

        u = find(u);
        v = find(v);

        if(uni(u, v)) {
            printf("%d - %d : %d\n", a, b, min);
            mincost += min;
            edges++;
        }

        cost[a][b] = cost[b][a] = 999;
    }

    printf("Total Cost = %d", mincost);

    return 0;
}
