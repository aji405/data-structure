#include <stdio.h>

#define V 5
#define INF 9999

int main() {
    int graph[V][V] = {
        {0, 2, 0, 6, 0},
        {2, 0, 3, 8, 5},
        {0, 3, 0, 0, 7},
        {6, 8, 0, 0, 9},
        {0, 5, 7, 9, 0}
    };

    int selected[V] = {0};
    int edge = 0, i, j, x, y;
    int min, cost = 0;

    selected[0] = 1;

    printf("Edges in MST:\n");

    while(edge < V - 1) {
        min = INF;

        for(i = 0; i < V; i++) {
            if(selected[i]) {
                for(j = 0; j < V; j++) {
                    if(!selected[j] && graph[i][j]) {
                        if(graph[i][j] < min) {
                            min = graph[i][j];
                            x = i;
                            y = j;
                        }
                    }
                }
            }
        }

        printf("%d - %d : %d\n", x, y, graph[x][y]);
        cost += graph[x][y];
        selected[y] = 1;
        edge++;
    }

    printf("Total Cost = %d", cost);

    return 0;
}
